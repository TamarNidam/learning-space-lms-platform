@model IEnumerable<Learning_Space.DTO.CourseDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
}


<h1 class="title">Courses</h1>
<hr/>

<div class="general">
    @if (permission == 0)
    {
        <p>
            <a asp-action="Create" asp-route-user="@user" asp-route-permission="@permission">&#xf055;</a>
        </p>
    }
    <div class="items_list">
        
        <div >
            <div>
                @Html.DisplayNameFor(model => model.CourseName)
            </div>
            @* <th>
                @Html.DisplayNameFor(model => model.CourseDescription)
            </th> *@
            <hr/>
                 
             @foreach (var item in Model) 
        {
                <div class="item" onclick="location.href='@Url.Action("Details", new { user = @user, permission = @permission, courseid = @item.CourseId })';">
                    <div>
                   
                     @Html.DisplayFor(modelItem => item.CourseName)
                     </div>
                
            @* <td>
                @Html.DisplayFor(modelItem => item.CourseDescription)
            </td> *@
                <div>
                @if(permission == 0 || permission == 1)
                {
                    <a asp-action="Edit" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@item.CourseId">&#x270E;</a>
                            if(permission == 0)
                            {
                            <a asp-action="Delete" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@item.CourseId">Delete</a>
                            }
                }
                
               @*  <a asp-action="Details" asp-route-id="@item.CourseId"> *@

                </div>
            </div>
        }
    </div>
    </div>
</div>