@model string

@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
    int? courseid = Convert.ToInt32(Context.Request.Query["courseid"]);
}

<style>
    h1 {
        color: #333;
        font-family: Arial, sans-serif;
        font-size: 24px;
        margin-bottom: 20px;
    }

    .notebook-content {
        width: 100%;
        height: 300px;
        padding: 10px;
        font-family: Arial, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    .notebook-content:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 5px #007bff;
    }

    .save-button {
        margin-top: 10px;
        background-color: #007bff;
        color: #fff;
        border: none;
        padding: 8px 16px;
        font-family: Arial, sans-serif;
        font-size: 14px;
        border-radius: 4px;
        cursor: pointer;
    }

    .save-button:hover {
        background-color: #0056b3;
    }
</style>

<h1>Notebook</h1>

<form asp-action="SaveNotebook" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@courseid">
    <textarea name="notebookContent" class="notebook-content">@Model</textarea>
    <button type="submit" class="save-button">Save</button>
</form>
<a asp-action="Details" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@courseid"><button type="submit" class="save-button">dont save</button></a>