@model IEnumerable<Learning_Space.DTO.ClassDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
}
<div class="general">
<h1>Classes</h1>

<p>
    <a asp-action="Create" asp-route-user="@user" asp-route-permission="@permission" >Create New</a>
</p>
<table class="items_list">

    <tbody>
@foreach (var item in Model) {
            <tr >

                <td onclick ="location.href='@Url.Action("Details", new { user = @user, permission = @permission, classid = @item.ClassId })';">
                @Html.DisplayFor(modelItem => item.ClassName)
            </td>
            <td>
                        <a class="icon" asp-action="Edit" asp-route-user="@user" asp-route-permission="@permission" asp-route-classid="@item.ClassId">&#x270E;</a>
                        <a class="icon" asp-action="Delete" asp-route-user="@user" asp-route-permission="@permission" asp-route-classid="@item.ClassId">&#x2716;</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>