@model IEnumerable<Learning_Space.DTO.CalendarDTO>

@{
    ViewData["Title"] = "Index";
}
@{
    DateTime currentDate = DateTime.Now;
    int currentYear = currentDate.Year;
    int currentMonth = currentDate.Month;
    int daysInMonth = DateTime.DaysInMonth(currentYear, currentMonth);
    DateTime firstDayOfMonth = new DateTime(currentYear, currentMonth, 1);
    int startDayOfWeek = (int)firstDayOfMonth.DayOfWeek;
    int totalDays = daysInMonth + startDayOfWeek;
    int rowCount = (int)Math.Ceiling((double)totalDays / 7);

    DateTime previousMonth = currentDate.AddMonths(-1);
    DateTime nextMonth = currentDate.AddMonths(1);
}


<h1>
    <a href="/Calendar/Index?currentDate=@previousMonth.ToString("yyyy-MM")">&lt;</a>
    Calendar - @currentDate.ToString("MMMM yyyy")
    <a href="/Calendar/Index?currentDate=@nextMonth.ToString("yyyy-MM")">&gt;</a>
</h1>

<table class="calendar">
    <tr class="days">
        <th>Sun</th>
        <th>Mon</th>
        <th>Tue</th>
        <th>Wed</th>
        <th>Thu</th>
        <th>Fri</th>
        <th>Sat</th>
    </tr>
    @for (int row = 0; row < rowCount; row++)
    {
        <tr class="week">
            @for (int col = 0; col < 7; col++)
            {
                int index = (row * 7) + col - startDayOfWeek + 1;
                if (index > 0 && index <= daysInMonth)
                {
                    DateTime date = new DateTime(currentYear, currentMonth, index);
                    bool hasEvent = Model != null && Model.Any(e => e.Date.Date == date.Date);

                    <td class="@(hasEvent ? "event-date" : "datInMonth")">@index</td>
                    @* <td class="@(hasEvent ? "event-date" : "empty-date")">@index</td> *@
                }
                else
                {
                    <td class="dayInMonth"></td>
                }
            }
        </tr>
    }
</table>

<br />

<a href="/Calendar/AddEvent">Add Event</a>
