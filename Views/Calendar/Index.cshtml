@model Learning_Space.DTO.CalendarDTO
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    public class CalendarView
    {
    public void DisplayMonthlyCalendar( calendar)
    {
        Console.WriteLine($"Calendar for {calendar.Month}/{calendar.Year}");

        foreach (var day in calendar.Days)
        {
            Console.WriteLine($"Day {day.Day}:");

            if (day.Events.Any())
            {
                foreach (var ev in day.Events)
                {
                    Console.WriteLine($" - {ev.Title} ({ev.Date.ToShortTimeString()}): {ev.Description}");
                }
            }
            else
            {
                Console.WriteLine(" - No events");
            }

            Console.WriteLine();
        }
    }
    }       
}
