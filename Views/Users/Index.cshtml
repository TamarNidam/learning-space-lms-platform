@model IEnumerable<Learning_Space.DTO.UserDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
}
 
<h1>Index</h1>

<p>
    <a asp-action="Create" asp-route-user="@user" asp-route-permission="@permission" asp-route-ts="s">Create New Student</a>
    <a asp-action="Create" asp-route-user="@user" asp-route-permission="@permission" asp-route-ts="t">Create New Teacher</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Role)
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
                <p/>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
                        <td>
                @Html.DisplayFor(modelItem => item.Role)
            </td>
        
            <td>
                <a asp-action="Edit" asp-route-user="0" asp-route-id="@item.UserId">Edit</a> |
                    <a asp-action="Details" asp-route-user="0" asp-route-id="@item.UserId">Details</a> |
                    <a asp-action="Delete" asp-route-user="0" asp-route-id="@item.UserId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
