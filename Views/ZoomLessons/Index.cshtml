@model IEnumerable<Learning_Space.Models.ZoomLesson>

@{
    ViewData["Title"] = "Index";
}
<link rel="stylesheet" type="text/css" href="./css/styles.css">
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ZoomUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lesson)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ZoomUrl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lesson.LessonType)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ZoomLesson1">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ZoomLesson1">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ZoomLesson1">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
