@model Learning_Space.Models.ZoomLesson

@{
    ViewData["Title"] = "Edit";
}
<link rel="stylesheet" type="text/css" href="./css/styles.css">
<h1>Edit</h1>

<h4>ZoomLesson</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ZoomLesson1" />
            <div class="form-group">
                <label asp-for="LessonId" class="control-label"></label>
                <select asp-for="LessonId" class="form-control" asp-items="ViewBag.LessonId"></select>
                <span asp-validation-for="LessonId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ZoomUrl" class="control-label"></label>
                <input asp-for="ZoomUrl" class="form-control" />
                <span asp-validation-for="ZoomUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="sign_up_button" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
