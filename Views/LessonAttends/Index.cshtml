@model IEnumerable<Learning_Space.Models.LessonAttend>

@{
    ViewData["Title"] = "Index";
}
<link rel="stylesheet" type="text/css" href="./css/styles.css">
<h1 class="title">Lesson Attend</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Attend)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lesson)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Attend)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lesson.LessonType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.User.FirstName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.LessonAttendId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.LessonAttendId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.LessonAttendId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
