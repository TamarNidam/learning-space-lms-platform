@model Learning_Space.Models.MoreStudy

@{
    ViewData["Title"] = "Create";
}
<link rel="stylesheet" type="text/css" href="./css/styles.css">
<h1>Create</h1>

<h4>MoreStudy</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MoreId" class="control-label"></label>
                <input asp-for="MoreId" class="form-control" />
