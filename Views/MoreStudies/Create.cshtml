@model Learning_Space.DTO.MoreStudyDTO

@{
    ViewData["Title"] = "Create";
}
@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
    int? courseid = Convert.ToInt32(Context.Request.Query["courseid"]);
    }

<h1>Create</h1>

<h4>MoreStudy</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@courseid">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MoreStudySubject" class="control-label"></label>
                <input asp-for="MoreStudySubject" class="form-control" />
                <span asp-validation-for="MoreStudySubject" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Content" class="control-label"></label>
                <input asp-for="Content" class="form-control" />
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MoreStudyUrl" class="control-label"></label>
                <input asp-for="MoreStudyUrl" class="form-control" />
                <span asp-validation-for="MoreStudyUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    @* <a asp-action="Index">Back to List</a> *@
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
