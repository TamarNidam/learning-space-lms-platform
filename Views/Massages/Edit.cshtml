@model Learning_Space.DTO.MassageDTO
@{
    ViewData["Title"] = "Edit";
}
@using Microsoft.AspNetCore.Http
@{
    int? user = Convert.ToInt32(Context.Request.Query["user"]);
    int? permission = Convert.ToInt32(Context.Request.Query["permission"]);
    int? courseid = Convert.ToInt32(Context.Request.Query["courseid"]);
}


<h1>Edit</h1>

<h4>Massage</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" asp-route-user="@user" asp-route-permission="@permission" asp-route-courseid="@courseid">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MessageId" />
          
            <div class="form-group">
                <label asp-for="MassageSubject" class="control-label"></label>
                <input asp-for="MassageSubject" class="form-control" />
                <span asp-validation-for="MassageSubject" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MassageDateTime" class="control-label"></label>
                <input asp-for="MassageDateTime" class="form-control" />
                <span asp-validation-for="MassageDateTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Content" class="control-label"></label>
                <input asp-for="Content" class="form-control" />
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="sign_up_button" />
            </div>
        </form>
    </div>
</div>

@* <div>
    <a asp-action="Index">Back to List</a>
</div> *@

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
